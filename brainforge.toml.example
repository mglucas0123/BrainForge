# Copy to your host project as brainforge.toml (or let `brainforge install` create it).

[brainforge]
version = "1"
memory_dir = ".brainforge/memory"
caveman_level = "full"   # lite | full | ultra
language = "pt-BR"

[install]
cursor = true
copilot = true
antigravity = true

[sync]
mode = "thin"   # thin = bridges only | mirror = full .cursor copy

[mcp]
enabled = true
